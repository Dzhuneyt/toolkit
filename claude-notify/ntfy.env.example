# ntfy.sh phone-push config for notify.sh — copy to ~/.claude/hooks/ntfy.env and fill in.
# The topic is a shared secret: anyone who knows it can read/publish. Keep it private; never commit the real value.
# To self-host instead of the public server, set NTFY_SERVER to your instance URL.
NTFY_TOPIC="REPLACE-with-a-random-unguessable-topic-e.g.-cc-<24-hex-chars>"
# NTFY_SERVER="https://ntfy.sh"
