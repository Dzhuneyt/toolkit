# ntfy.sh phone-push config for notify.sh — copy to ~/.claude/hooks/ntfy.env and fill in.
# The topic is a shared secret: anyone who knows it can read/publish. Keep it private; never commit the real value.
# To self-host instead of the public server, set NTFY_SERVER to your instance URL.
NTFY_TOPIC="REPLACE-with-a-random-unguessable-topic-e.g.-cc-<24-hex-chars>"
# NTFY_SERVER="https://ntfy.sh"

# Skip the phone push when the desk is actively used (idle < threshold) or during
# quiet hours. Desk notification still fires in both cases — only the phone push
# is suppressed. Set the _ENABLED var to 0 to disable a gate entirely.
# NTFY_IDLE_GATE_ENABLED=1
# NTFY_IDLE_THRESHOLD_SECONDS=180
# NTFY_QUIET_HOURS_ENABLED=1
# NTFY_QUIET_HOURS_START=22
# NTFY_QUIET_HOURS_END=8
